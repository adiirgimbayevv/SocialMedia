{
  "info": {
    "name": "Echoes Social Network API",
    "description": "Полная коллекция для тестирования социальной сети (2026)",
    "_postman_id": "echoes-social-2026"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Get Feed (All Posts)",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/posts?page=1&limit=10",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Post by ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/posts/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/posts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Это мой первый пост в Echoes! 🚀\"\n}"
            }
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/posts/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Обновлённый текст поста\"\n}"
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/posts/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Get Comments for Post",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/posts/1/comments?page=1&limit=10",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/posts/1/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Отличный пост! Согласен полностью.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users (Follow)",
      "item": [
        {
          "name": "Follow User",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/users/2/follow",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Unfollow User",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/users/2/unfollow",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}